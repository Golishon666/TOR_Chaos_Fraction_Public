    <string id="tor_chaos_title" text="카오스 언디바이디드 챔피언" />
    <string id="tor_chaos_rank1" text="파멸의 입회자" />
    <string id="tor_chaos_rank2" text="어둠의 신들의 총애를 받는" />
    <string id="tor_chaos_rank3" text="판테온의 에버초즌" />
    <string id="tor_chaos_desc" text="희생, 암흑 마법, 중갑, 네 신 모두의 은총을 통해 다스리는 걸어다니는 재앙입니다." />
    <string id="tor_chaos_rite_label" text="승천의 의례" />
    <string id="tor_chaos_rite_desc" text="단기적인 승천: 두려움, 속도, 저항, 근접 분노, 어둠의 마법이 챔피언 주위로 쇄도합니다." />
    <string id="tor_chaos_cc_option_text" text="카오스 언디바이디드 챔피언" />
    <string id="tor_chaos_cc_effect_text" text="카오스 커리어" />
    <string id="tor_chaos_cc_flavour_text" text="당신은 피와 마법과 파멸의 길을 걸어왔습니다. 신들이 당신의 발뒤꿈치에 속삭이고, 약한 자들은 곧 무릎을 꿇는 법을 배우게 될 것입니다." />
    <string id="tor_chaos_cc_origin_option_text" text="워밴드의 후예" />
    <string id="tor_chaos_cc_origin_effect_text" text="워밴드 오리진" />
    <string id="tor_chaos_cc_origin_flavour_text" text="당신은 철 깃발과 비명을 지르는 하늘 아래에서 자랐으며, 자비는 약함이며 생존은 그것을 취하는 자의 것임을 일찍부터 배웠습니다." />
    <string id="tor_chaos_cc_growth_option_text" text="피묻은 지원자" />
    <string id="tor_chaos_cc_growth_effect_text" text="피묻은 지원자" />
    <string id="tor_chaos_cc_growth_flavour_text" text="당신의 젊음은 습격, 매복, 구덩이 싸움에서 자신을 증명하는 데 소비되었으며, 당신은 신의 관심을 받을 가치가 있는 사람으로 표시되는 흉터를 얻었습니다." />
    <string id="tor_chaos_culture_name_text" text="카오스" />
    <string id="tor_chaos_cc_culture_name_text" text="카오스" />
    <string id="tor_chaos_cc_culture_short_text" text="카오스" />
    <string id="tor_chaos_cc_culture_desc_text" text="Chaos Undivided의 챔피언은 파괴적인 힘의 두려운 하수인으로 시작하여 희생, 암흑 마법, 차원문, 네 신에 대한 헌신을 통해 힘을 얻습니다." />
    <string id="tor_chaos_gifts_name" text="카오스 선물" />
    <string id="tor_chaos_gifts_desc" text="카오스 선물은 희생, 처형, 파괴된 정착지 및 승리를 통해 획득됩니다. 헌신, 봉기, 포털 의식에 사용하세요." />
    <string id="tor_chaos_invasion_name" text="카오스 침공" />
    <string id="tor_chaos_invasion_desc" text="처형, 포털, 희생 및 봉기로 관심을 끌었습니다. 더 높은 단계에서는 악마사냥꾼을 부르고 결국 카오스에 맞서 영역을 통합합니다." />
    <string id="tor_chaos_enchant_title" text="파멸적인 비밀을 선택하세요..." />
    <string id="tor_chaos_enchant_desc" text="포털에서 배우려면 금지된 마법을 선택하세요." />
