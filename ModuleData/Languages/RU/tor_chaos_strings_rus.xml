    <string id="tor_chaos_rank3" text="Вечноизбранный Пантеона" />
    <string id="tor_chaos_desc" text="Ходячее бедствие, правящее посредством жертвоприношений, темной магии, тяжелых доспехов и благосклонности всех четырех богов." />
    <string id="tor_chaos_rite_label" text="Обряд Восхождения" />
    <string id="tor_chaos_rite_desc" text="Кратковременное вознесение: страх, скорость, сопротивление, ярость ближнего боя и темная магия окружают чемпиона." />
    <string id="tor_chaos_cc_option_text" text="Чемпион Хаоса Неделимого" />
    <string id="tor_chaos_cc_effect_text" text="Карьера Хаоса" />
    <string id="tor_chaos_cc_flavour_text" text="Вы прошли путь крови, колдовства и разрушения. Боги шепчут вам по пятам, и слабые скоро научатся становиться на колени." />
    <string id="tor_chaos_cc_origin_option_text" text="Отпрыск отряда" />
    <string id="tor_chaos_cc_origin_effect_text" text="Происхождение отряда" />
    <string id="tor_chaos_cc_origin_flavour_text" text="Вас воспитали под железными знаменами и кричащими небесами, вас рано научили, что милосердие — это слабость, и выживание принадлежит тем, кто его принимает." />
    <string id="tor_chaos_cc_growth_option_text" text="Кровавый претендент" />
    <string id="tor_chaos_cc_growth_effect_text" text="Кровавый претендент" />
    <string id="tor_chaos_cc_growth_flavour_text" text="Ваша юность прошла, доказывая себя в рейдах, засадах и боях на ямах, зарабатывая шрамы, которые отмечали вас как человека, достойного внимания богов." />
    <string id="tor_chaos_culture_name_text" text="Хаос" />
    <string id="tor_chaos_cc_culture_name_text" text="Хаос" />
    <string id="tor_chaos_cc_culture_short_text" text="Хаос" />
    <string id="tor_chaos_cc_culture_desc_text" text="Чемпион Chaos Undivided начинается как грозный слуга Губительных Сил, набирающий силу посредством жертвоприношений, темной магии, порталов и преданности четырем богам." />
    <string id="tor_chaos_gifts_name" text="Дары Хаоса" />
    <string id="tor_chaos_gifts_desc" text="Дары Хаоса зарабатываются посредством жертвоприношений, казней, разрушений поселений и побед. Потратьте их на преданность, восстания и портальные обряды." />
    <string id="tor_chaos_invasion_name" text="Вторжение Хаоса" />
    <string id="tor_chaos_invasion_desc" text="Насколько мир заметил ваши злодеяния. Растёт от казней лордов, порталов, жертв в деревнях и восстаний. Выше стадия — сильнее ответ: появляются Охотники на Демонов, а на максимуме королевства объединяются против вас." />
    <string id="tor_chaos_enchant_title" text="Выбери губительную тайну..." />
    <string id="tor_chaos_enchant_desc" text="Выберите запрещенное заклинание, чтобы изучить его на портале." />
    <string id="tor_chaos_cc_origin_fallen_noble_option_text" text="Падший дворянин" />
    <string id="tor_chaos_cc_origin_fallen_noble_effect_text" text="Опальная родословная" />
    <string id="tor_chaos_cc_origin_fallen_noble_flavour_text" text="Вы были рождены, чтобы командовать, но старые законы оказались слишком малы для ваших амбиций. Север ответил там, где придворные клятвы не помогли." />
    <string id="tor_chaos_cc_origin_dark_acolyte_option_text" text="Темный послушник" />
    <string id="tor_chaos_cc_origin_dark_acolyte_effect_text" text="Запрещенное исследование" />
    <string id="tor_chaos_cc_origin_dark_acolyte_flavour_text" text="Вы узнали слова, обжигающие язык, и символы, привлекающие взгляды из-за завесы." />
    <string id="tor_chaos_cc_growth_cult_handler_option_text" text="Культовый куратор" />
    <string id="tor_chaos_cc_growth_cult_handler_effect_text" text="Скрытые ячейки" />
    <string id="tor_chaos_cc_growth_cult_handler_flavour_text" text="Вы разносили шепот между подвалами, храмами и тюремными повозками, пока ваш знак не узнали целые улицы." />
    <string id="tor_chaos_cc_growth_raider_option_text" text="Северный рейдер" />
