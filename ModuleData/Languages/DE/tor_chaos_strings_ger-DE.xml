    <string id="tor_chaos_cc_option_text" text="Champion des Ungeteilten Chaos" />
    <string id="tor_chaos_cc_effect_text" text="Chaos-Karriere" />
    <string id="tor_chaos_cc_flavour_text" text="Du bist den Weg des Blutes, der Zauberei und des Verderbens gegangen. Die Götter flüstern dir auf den Fersen, und die Schwachen werden bald lernen, zu knien." />
    <string id="tor_chaos_cc_origin_option_text" text="Spross der Kriegerschar" />
    <string id="tor_chaos_cc_origin_effect_text" text="Ursprung der Kriegerschar" />
    <string id="tor_chaos_cc_origin_flavour_text" text="Du wurdest unter eisernen Bannern und schreienden Himmeln erzogen und schon früh wurde dir beigebracht, dass Barmherzigkeit Schwäche ist und dass das Überleben denen gehört, die sie annehmen." />
    <string id="tor_chaos_cc_growth_option_text" text="Blutiger Aspirant" />
    <string id="tor_chaos_cc_growth_effect_text" text="Blutiger Aspirant" />
    <string id="tor_chaos_cc_growth_flavour_text" text="In deiner Jugend hast du dich bei Überfällen, Hinterhalten und Grubenkämpfen bewiesen und dir Narben eingebracht, die dich als jemand kennzeichneten, der der Aufmerksamkeit der Götter würdig war." />
    <string id="tor_chaos_culture_name_text" text="Chaos" />
    <string id="tor_chaos_cc_culture_name_text" text="Chaos" />
    <string id="tor_chaos_cc_culture_short_text" text="Chaos" />
    <string id="tor_chaos_cc_culture_desc_text" text="Ein Champion von Chaos Undivided beginnt als gefürchteter Diener der ruinösen Mächte und gewinnt durch Opfer, dunkle Magie, Portale und Hingabe an die vier Götter an Stärke." />
    <string id="tor_chaos_gifts_name" text="Gaben des Chaos" />
    <string id="tor_chaos_gifts_desc" text="Chaosgeschenke werden durch Opfer, Hinrichtungen, zerstörte Siedlungen und Siege verdient. Geben Sie sie für Hingabe, Aufstände und Portalriten aus." />
    <string id="tor_chaos_invasion_name" text="Chaos-Invasion" />
    <string id="tor_chaos_invasion_desc" text="Die Aufmerksamkeit, die durch Hinrichtungen, Portale, Opfer und Aufstände erregt wird. Höhere Stufen rufen Dämonenjäger herbei und vereinen schließlich die Reiche gegen das Chaos." />
    <string id="tor_chaos_enchant_title" text="Wähle ein ruinöses Geheimnis ..." />
    <string id="tor_chaos_enchant_desc" text="Wählen Sie eine verbotene Verzauberung aus, um sie vom Portal zu lernen." />
    <string id="tor_chaos_cc_origin_fallen_noble_option_text" text="Gefallener Adliger" />
    <string id="tor_chaos_cc_origin_fallen_noble_effect_text" text="In Ungnade gefallene Blutlinie" />
    <string id="tor_chaos_cc_origin_fallen_noble_flavour_text" text="Sie wurden zum Befehlen geboren, aber die alten Gesetze erwiesen sich als zu gering für Ihren Ehrgeiz. Der Norden antwortete, wo höfische Eide versagten." />
    <string id="tor_chaos_cc_origin_dark_acolyte_option_text" text="Dunkler Akolyth" />
