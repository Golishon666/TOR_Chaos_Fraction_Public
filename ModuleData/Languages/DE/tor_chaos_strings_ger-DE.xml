    <string id="tor_chaos_rank3" text="Immerauserwählter des Pantheons" />
    <string id="tor_chaos_desc" text="Eine wandelnde Katastrophe, die durch Opfer, dunkle Magie, schwere Rüstung und die Gunst aller vier Götter herrscht." />
    <string id="tor_chaos_rite_label" text="Ritus des Aufstiegs" />
