  <string id="tor_chaos_devotion_reward_khorne_2" text="{=tor_chaos_devotion_reward_khorne_2_text}Arrows pierce shields and you gain +5% physical resistance." />
  <string id="tor_chaos_devotion_reward_khorne_3" text="{=tor_chaos_devotion_reward_khorne_3_text}Unlocks Prayer: Khorne's Fortitude." />
  <string id="tor_chaos_devotion_reward_khorne_4" text="{=tor_chaos_devotion_reward_khorne_4_text}Melee strikes deal 1000% shield damage." />
  <string id="tor_chaos_devotion_reward_khorne_5" text="{=tor_chaos_devotion_reward_khorne_5_text}Charging horses that hit you collapse with their riders." />
  <string id="tor_chaos_devotion_reward_khorne_6" text="{=tor_chaos_devotion_reward_khorne_6_text}Each kill grants +1 swing speed, up to +20." />
