  <string id="tor_chaos_devotion_reward_nurgle_10" text="{=tor_chaos_devotion_reward_nurgle_10_text}Nurgle armor set: 5 pieces; each +5% phys resist, +5% ward, +5 HP, +10% ranged resistance." />
