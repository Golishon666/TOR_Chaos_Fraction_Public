<strings>
  <string id="tor_career_title.ChaosChampionUndivided" text="{=tor_chaos_title}Chaos Champion Undivided" />
  <string id="tor_career_rank1_name.ChaosChampionUndivided" text="{=tor_chaos_rank1}Initiate of Ruin" />
  <string id="tor_career_rank2_name.ChaosChampionUndivided" text="{=tor_chaos_rank2}Favored of the Dark Gods" />
  <string id="tor_career_rank3_name.ChaosChampionUndivided" text="{=tor_chaos_rank3}Everchosen of the Pantheon" />
  <string id="tor_career_description.ChaosChampionUndivided" text="{=tor_chaos_desc}Chosen by the four dark gods, you are the blade of the End Times, sworn to drown this world in ruin." />

  <string id="chaos_rite_of_ascendancy_label" text="{=tor_chaos_rite_label}Rite of Ascendancy" />
  <string id="chaos_rite_of_ascendancy_desc" text="{=tor_chaos_rite_desc}Lasts 18 seconds. Grants +20% physical resistance, +5% ward, +25% melee damage, +20% spell damage, +15% movement and +15% attack speed. Nearby enemies are slowed; Chaos allies gain resistance, damage and movement." />

  <string id="tor_chaos_cc_option" text="{=tor_chaos_cc_option_text}Chaos Champion Undivided" />
  <string id="tor_chaos_cc_effect" text="{=tor_chaos_cc_effect_text}Chaos Career" />
  <string id="tor_chaos_cc_flavour" text="{=tor_chaos_cc_flavour_text}You have walked the path of blood, sorcery and ruin. The gods whisper at your heels, and the weak will soon learn to kneel." />
  <string id="tor_chaos_cc_origin_option" text="{=tor_chaos_cc_origin_option_text}Scion of the Warband" />
  <string id="tor_chaos_cc_origin_effect" text="{=tor_chaos_cc_origin_effect_text}Warband Origin" />
  <string id="tor_chaos_cc_origin_flavour" text="{=tor_chaos_cc_origin_flavour_text}You were raised beneath iron banners and screaming skies, taught early that mercy is weakness and survival belongs to those who take it." />
  <string id="tor_chaos_cc_growth_option" text="{=tor_chaos_cc_growth_option_text}Blooded Aspirant" />
  <string id="tor_chaos_cc_growth_effect" text="{=tor_chaos_cc_growth_effect_text}Blooded Aspirant" />
  <string id="tor_chaos_cc_growth_flavour" text="{=tor_chaos_cc_growth_flavour_text}Your youth was spent proving yourself in raids, ambushes and pit fights, earning scars that marked you as one worthy of the gods' attention." />
  <string id="tor_chaos_culture_name" text="{=tor_chaos_culture_name_text}Chaos" />
  <string id="tor_chaos_cc_culture_name" text="{=tor_chaos_cc_culture_name_text}Chaos" />
  <string id="tor_chaos_cc_culture_short" text="{=tor_chaos_cc_culture_short_text}Chaos" />
  <string id="tor_chaos_cc_culture_desc" text="{=tor_chaos_cc_culture_desc_text}A champion of Chaos Undivided begins as a feared servant of the Ruinous Powers, gaining strength through sacrifice, dark magic, portals and devotion to the four gods." />
  <string id="tor_custom_resource_name.ChaosGifts" text="{=tor_chaos_gifts_name}Chaos Gifts" />
  <string id="tor_custom_resource_description.ChaosGifts" text="{=tor_chaos_gifts_desc}Chaos Gifts are earned through sacrifices, executions, ruined settlements and victories. Spend them on devotion, uprisings and portal rites." />
  <string id="tor_custom_resource_name.ChaosInvasion" text="{=tor_chaos_invasion_name}Chaos Invasion" />
  <string id="tor_custom_resource_description.ChaosInvasion" text="{=tor_chaos_invasion_desc}How much the world has noticed your atrocities. Rises when you execute lords, open portals, sacrifice villages, or trigger uprisings. Higher stages send Demon Hunters; at maximum the realms unite against you." />
  <string id="tor_enchantmentshop_title.chaos_culture" text="{=tor_chaos_enchant_title}Choose a ruinous secret..." />
  <string id="tor_enchantmentshop_description.chaos_culture" text="{=tor_chaos_enchant_desc}Select a forbidden enchantment to learn from the portal." />

  <string id="tor_chaos_cc_origin_fallen_noble_option" text="{=tor_chaos_cc_origin_fallen_noble_option_text}Fallen Noble" />
  <string id="tor_chaos_cc_origin_fallen_noble_effect" text="{=tor_chaos_cc_origin_fallen_noble_effect_text}Disgraced Bloodline" />
  <string id="tor_chaos_cc_origin_fallen_noble_flavour" text="{=tor_chaos_cc_origin_fallen_noble_flavour_text}You were born to command, but the old laws proved too small for your ambition. The north answered where courtly oaths failed." />
  <string id="tor_chaos_cc_origin_dark_acolyte_option" text="{=tor_chaos_cc_origin_dark_acolyte_option_text}Dark Acolyte" />
  <string id="tor_chaos_cc_origin_dark_acolyte_effect" text="{=tor_chaos_cc_origin_dark_acolyte_effect_text}Forbidden Study" />
  <string id="tor_chaos_cc_origin_dark_acolyte_flavour" text="{=tor_chaos_cc_origin_dark_acolyte_flavour_text}You learned the words that burn the tongue and the sigils that draw eyes from beyond the veil." />
  <string id="tor_chaos_cc_growth_cult_handler_option" text="{=tor_chaos_cc_growth_cult_handler_option_text}Cult Handler" />
  <string id="tor_chaos_cc_growth_cult_handler_effect" text="{=tor_chaos_cc_growth_cult_handler_effect_text}Hidden Cells" />
  <string id="tor_chaos_cc_growth_cult_handler_flavour" text="{=tor_chaos_cc_growth_cult_handler_flavour_text}You carried whispers between cellars, shrines and prison carts until whole streets knew your sign." />
  <string id="tor_chaos_cc_growth_raider_option" text="{=tor_chaos_cc_growth_raider_option_text}Northern Raider" />
  <string id="tor_chaos_cc_growth_raider_effect" text="{=tor_chaos_cc_growth_raider_effect_text}Blooded by Raids" />
  <string id="tor_chaos_cc_growth_raider_flavour" text="{=tor_chaos_cc_growth_raider_flavour_text}Your first lessons were fire, mud and steel, taken from villages that learned your name too late." />

