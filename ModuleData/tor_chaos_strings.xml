  <string id="tor_chaos_devotion_reward_khorne_10" text="{=tor_chaos_devotion_reward_khorne_10_text}Legendary two-handed axe of Khorne: massive damage, cleave, shockwave on hit, and heals 3 HP per kill." />
  <string id="tor_chaos_devotion_reward_nurgle_1" text="{=tor_chaos_devotion_reward_nurgle_1_text}+2 campaign movement speed." />
